// IL-2 Great Battles — Dedicated Server Definition Script
// Copy this file to il2-data/data/server.sds and fill in your details.

// credentials

login = "your@email.com"
password = "yourIL2password"

// server info

ranked = 0
mode = 0
banTimeout = 900
lobbyTimer = 30
coopQuorum = 0
allowMouseJoy = 1
ServerName = "My IL-2 Server"
TacviewRecord = false

serverDesc = "A great IL-2 server"

// SRS comm server IP:Port ("255.255.255.255:1234") or URL:Port ("srs.host.com:1234")
srsCommServer = ""

// connection settings

protection = ""
maxClients = 10
maxClientPing = -1
ExternalIP = 1
ServerIP = "0.0.0.0"
DownloadLimit = 50000
UploadLimit = 50000
DownloaderPort = 28100
TCPPort = 28000
UDPPort = 28000

// remote console settings

RconStart = 0
RconIP = ""
RconPort = 8991
RconLogin = ""
RconPassword = ""

// mission rotation data

ShutdownLoads = -1

[rotation]
random = false
// Add mission entries below this line, one per line:
// "data/Multiplayer/Dogfight/YourMission.Mission" turntime_minutes checkairfields(0/1) refighttime_seconds
// Example:
// "data/Multiplayer/Dogfight/MyMap.Mission" 60 1 0
[end]

// preset and advanced settings

preset = 1

// preset: server related

killNotification = 1
friendlyFireReturn = 0
finishMissionIfLanded = 0
lockPayloads = 0
lockSkins = 0
lockFuelLoads = 0
lockWeaponModes = 0
lockPlayerTankAIaimAtObj = 0
lockInjectors = 0
AllowExtCamSpectator = true
penaltyTimeout = 10
respawnTimeout = 0
coalitionChangeTimeout = 10
finishMissionTimeout = 0
missionEndTimeout = 0
idleKickTimeout = 0
tdmPointsPerRound = 0
tdmRoundTime = 0
coalitionsBalancer = false
allowMarshals = false
useMarshalsRestriction = false

// preset: mission related

objectIcons = true
navigationIcons = true
aimingHelp = false
courseWeaponsAimingHelp = false
padlock = true
simpleDevices = true
techChatMessages = true
techChatAdvices = false
AllowExtCamPlayer = true

easyFlight = false
autoCoordination = false
autoThrottle = false
autoPilot = true
autoThrottleLimit = true
autoMix = true
autoRadiator = true

noMoment = false
noWind = false
noMisfire = false
noBreak = false
invulnerability = false
simplePhysiology = false
unlimitFuel = false
unlimitAmmo = false
engineNoStop = false
hotEngine = true
alterVisibility = false
